---
// index.astro - BDI KKU Automated AI NMR Spectroscopy Dashboard (Astro Version)
---
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI NMR Spectroscopy Diagnostic Hub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Load Plotly.js from CDN for zero-overhead, blazing fast rendering -->
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js" is:inline></script>
</head>
<body>
    <div class="app-container">
        
        <!-- --- HEADER BAR --- -->
        <header class="main-header">
            <div class="logo-container">
                <span class="logo-icon">🌌</span>
                <div>
                    <h1>AI NMR Spectroscopy Diagnostic Hub</h1>
                    <p class="subtitle">TRL 5+ Automated Physics-Aware Metabolomics Pipeline</p>
                </div>
            </div>
            <div class="tech-badge">
                <span class="pulse-dot"></span>
                <span>FastAPI + Astro Hybrid Live</span>
            </div>
        </header>

        <!-- --- MAIN CLINICAL DASHBOARD GRID --- -->
        <div class="dashboard-grid">
            
            <!-- --- LEFT COLUMN: CONTROL PANEL --- -->
            <aside class="sidebar glass-card">
                <h3 class="panel-title">🔬 Clinical Simulator Controls</h3>
                <p class="panel-desc">Adjust spectrometer perturbations to evaluate neural model tolerance in real time.</p>
                
                <hr class="divider" />
                
                <!-- Sample selection -->
                <div class="control-group">
                    <label for="sample-select">Load Patient Profile</label>
                    <select id="sample-select" class="form-select">
                        <option value="Plant_Extract_A">Patient #001 (Sugarcane - Sugar-Rich)</option>
                        <option value="Plant_Extract_B">Patient #002 (Coffee - Aromatic-Rich)</option>
                        <option value="Plant_Extract_C">Patient #003 (Soybean - Amino-Acid-Rich)</option>
                    </select>
                </div>
                
                <!-- File Upload -->
                <div class="control-group">
                    <label for="file-upload">Upload Raw NMR File (CSV/TXT)</label>
                    <input type="file" id="file-upload" class="form-file" accept=".csv,.txt" />
                    <span class="help-text">Directly parses columns and maps onto AI models.</span>
                </div>
                
                <hr class="divider" />

                <!-- Slide Perturbations -->
                <div class="control-group">
                    <div class="slider-header">
                        <label for="noise-slider">Spectrometer Baseline Noise</label>
                        <span id="noise-val" class="slider-val">0.015</span>
                    </div>
                    <input type="range" id="noise-slider" class="form-slider" min="0.005" max="0.08" step="0.005" value="0.015" />
                </div>

                <div class="control-group">
                    <div class="slider-header">
                        <label for="drift-slider">Chemical Shift Drift (ppm)</label>
                        <span id="drift-val" class="slider-val">+0.015</span>
                    </div>
                    <input type="range" id="drift-slider" class="form-slider" min="-0.04" max="0.04" step="0.005" value="0.015" />
                </div>
                
                <hr class="divider" />

                <!-- EBM Constraints -->
                <h4 class="sub-panel-title">🛡️ Physics Constraint Gate</h4>
                
                <div class="control-group checkbox-container">
                    <input type="checkbox" id="ghost-checkbox" />
                    <label for="ghost-checkbox">
                        Inject Anomalous Ghost Peak
                        <span class="help-text">Simulates high-energy contaminant peak violating spin-spin coupling laws.</span>
                    </label>
                </div>

                <div class="control-group">
                    <div class="slider-header">
                        <label for="ebm-slider">EBM Energy Alarm Limit</label>
                        <span id="ebm-val" class="slider-val">1.1</span>
                    </div>
                    <input type="range" id="ebm-slider" class="form-slider" min="0.5" max="2.0" step="0.1" value="1.1" />
                </div>

                <button id="analyze-btn" class="btn-primary">
                    <span class="btn-text">⚡ Run AI Diagnostic Analysis</span>
                    <span class="btn-loader hidden"></span>
                </button>
            </aside>

            <!-- --- MIDDLE COLUMN: DUAL-PANE SPECTROSCOPIC WORKSPACE --- -->
            <main class="main-content">
                
                <!-- Status Cards -->
                <div class="scorecard-grid">
                    <div class="scorecard blue-left">
                        <span class="card-label">PATIENT SAMPLE ID</span>
                        <h4 id="scorecard-id">NMR-SAMPLE-2026-X99</h4>
                    </div>
                    <div class="scorecard purple-left">
                        <span class="card-label">SCREENED EXTRACT</span>
                        <h4 id="scorecard-extract">Sugarcane Extract</h4>
                    </div>
                    <div class="scorecard emerald-left">
                        <span class="card-label">ANALYSIS STATUS</span>
                        <h4 id="scorecard-status">Pending Analysis</h4>
                    </div>
                    <div class="scorecard gray-left" id="scorecard-qc-box">
                        <span class="card-label">PHYSICS QC CHECK</span>
                        <h4 id="scorecard-qc">UNVERIFIED</h4>
                    </div>
                </div>

                <!-- Alert Banner -->
                <div id="alert-banner" class="alert-banner hidden">
                    <span class="badge badge-amber" id="alert-badge">ANOMALY DETECTED</span>
                    <h3 id="alert-title">Diagnostic Alert</h3>
                    <p id="alert-desc">Alert details...</p>
                </div>

                <!-- Dual Spectrum Plots -->
                <div class="workspace-grid">
                    <div class="plot-container glass-card">
                        <div class="plot-header">
                            <h4>Pane A: Active Patient Signal & High-Res Zoom Inset</h4>
                            <span class="info-tag">Interactive Zoomable Plotly Chart</span>
                        </div>
                        <div id="plotly-overlay" class="chart-canvas"></div>
                        
                        <div class="zoom-inset-header">
                            <span class="zoom-title">🔍 High-Resolution Zoom Inset: Sugar Region (3.2 - 4.5 ppm)</span>
                        </div>
                        <div id="plotly-zoom" class="zoom-canvas"></div>
                    </div>

                    <div class="plot-container glass-card">
                        <div class="plot-header">
                            <h4>Pane B: Spectroscopic Reference Library Waterfall Stack</h4>
                            <span class="info-tag">Vertical Offset Stack</span>
                        </div>
                        <div id="plotly-waterfall" class="chart-canvas-tall"></div>
                    </div>
                </div>

                <!-- Biomarker Table -->
                <div class="table-container glass-card">
                    <h4>Identified Biomarkers & Quantitative Relative Abundance</h4>
                    <p class="table-desc">Statistical deconvolution of NMR peak integrals mapped directly to HMDB reference databases.</p>
                    <div class="table-wrapper">
                        <table id="biomarker-table">
                            <thead>
                                <tr>
                                    <th>Metabolite Biomarker</th>
                                    <th>Chemical Formula</th>
                                    <th>HMDB Ref</th>
                                    <th>Match Confidence</th>
                                    <th>Relative Concentration (Integral)</th>
                                </tr>
                            </thead>
                            <tbody id="biomarker-tbody">
                                <!-- Loaded dynamically -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Technical Expandable Area -->
                <div class="accordion glass-card">
                    <button class="accordion-trigger" id="accordion-toggle">
                        <span>🛠️ Advanced AI Engine & Machine Learning Diagnostics (Technical Grading Panel)</span>
                        <span class="arrow">▼</span>
                    </button>
                    
                    <div class="accordion-content hidden" id="accordion-panel">
                        <h4 class="tech-section-title">Stage 1 & 2: Generative Latent Projection & Neural ODE Integration</h4>
                        <div class="tech-row">
                            <div class="tech-col">
                                <h5>Latent Feature Activation (128 Dimensions)</h5>
                                <div id="plotly-latent" class="tech-chart"></div>
                            </div>
                            <div class="tech-col">
                                <h5>Latent ODE Integration Trajectory</h5>
                                <div id="plotly-ode" class="tech-chart"></div>
                            </div>
                        </div>

                        <hr class="divider" />

                        <h4 class="tech-section-title">Stage 3 & 4: Physics-Constrained EBM Engine & EHR hospital Payload</h4>
                        <div class="tech-row">
                            <div class="tech-col-narrow">
                                <h5>EBM Physics Energy Score</h5>
                                <div class="gauge-wrapper">
                                    <div class="gauge-circle" id="gauge-circle">
                                        <div class="gauge-value" id="gauge-val">0.000</div>
                                        <div class="gauge-label" id="gauge-lbl">STABLE</div>
                                    </div>
                                </div>
                            </div>
                            <div class="tech-col-wide">
                                <h5>Structured Diagnostic EMR JSON Payload</h5>
                                <pre class="json-code" id="json-payload">&#123; "status": "Run pipeline analysis to load hospital payload..." &#125;</pre>
                                <button class="btn-secondary" id="download-json-btn">📥 Download Clinical JSON Payload</button>
                            </div>
                        </div>
                    </div>
                </div>

            </main>
        </div>
    </div>

    <!-- --- PREMIUM VANILLA CSS DESIGN SYSTEM --- -->
    <style>
        :root {
            --bg-color: #F8FAFC;
            --text-main: #1E293B;
            --text-heading: #0F172A;
            --card-bg: #FFFFFF;
            --border-color: #E2E8F0;
            --primary: #0284C7;
            --primary-hover: #0269A1;
            --primary-light: #E0F2FE;
            --emerald: #10B981;
            --emerald-bg: #D1FAE5;
            --emerald-text: #065F46;
            --amber: #F59E0B;
            --amber-bg: #FEF3C7;
            --amber-text: #92400E;
            --red: #EF4444;
            --red-bg: #FEE2E2;
            --red-text: #991B1B;
            --purple: #8B5CF6;
            --purple-bg: #EDE9FE;
            --purple-text: #5B21B6;
            --font-main: 'Outfit', sans-serif;
            --font-code: 'Space Grotesk', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--font-main);
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        .app-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 24px;
        }

        /* --- HEADER --- */
        .main-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border-color);
        }

        .logo-container {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .logo-icon {
            font-size: 2.8rem;
        }

        .main-header h1 {
            font-family: var(--font-code);
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-heading);
            margin: 0;
            letter-spacing: -0.02em;
        }

        .subtitle {
            font-size: 0.95rem;
            color: #64748B;
            margin: 4px 0 0 0;
        }

        .tech-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            background-color: var(--emerald-bg);
            color: var(--emerald-text);
            padding: 6px 16px;
            border-radius: 9999px;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            border: 1px solid #A7F3D0;
        }

        .pulse-dot {
            width: 8px;
            height: 8px;
            background-color: var(--emerald);
            border-radius: 50%;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(0.9); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.4; }
            100% { transform: scale(0.9); opacity: 1; }
        }

        /* --- LAYOUT GRID --- */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 24px;
            align-items: start;
        }

        /* --- GLASS CARD AESTHETIC --- */
        .glass-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px -1px rgba(0, 0, 0, 0.05);
        }

        .sidebar {
            position: sticky;
            top: 24px;
        }

        .panel-title {
            font-family: var(--font-code);
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text-heading);
            margin: 0 0 8px 0;
        }

        .panel-desc {
            font-size: 0.85rem;
            color: #64748B;
            margin: 0 0 16px 0;
            line-height: 1.4;
        }

        .divider {
            border: 0;
            border-top: 1px solid var(--border-color);
            margin: 16px 0;
        }

        .control-group {
            margin-bottom: 20px;
        }

        .control-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-heading);
            margin-bottom: 8px;
        }

        .form-select {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-family: var(--font-main);
            font-size: 0.9rem;
            color: var(--text-main);
            background-color: #F8FAFC;
            cursor: pointer;
            transition: border-color 0.2s;
        }

        .form-select:focus {
            border-color: var(--primary);
            outline: none;
        }

        .form-file {
            width: 100%;
            padding: 8px 10px;
            border: 1px dashed var(--border-color);
            border-radius: 8px;
            font-family: var(--font-main);
            font-size: 0.85rem;
            background-color: #F8FAFC;
            cursor: pointer;
            box-sizing: border-box;
        }
        .form-file:hover {
            border-color: var(--primary);
        }

        .slider-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }

        .slider-val {
            font-family: var(--font-code);
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--primary);
        }

        .form-slider {
            width: 100%;
            height: 6px;
            background: #E2E8F0;
            border-radius: 999px;
            outline: none;
            -webkit-appearance: none;
            cursor: pointer;
        }

        .form-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: var(--primary);
            transition: transform 0.1s;
        }

        .form-slider::-webkit-slider-thumb:hover {
            transform: scale(1.2);
        }

        .sub-panel-title {
            font-family: var(--font-code);
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text-heading);
            margin: 0 0 12px 0;
        }

        .checkbox-container {
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .checkbox-container input[type="checkbox"] {
            margin-top: 4px;
            cursor: pointer;
            width: 16px;
            height: 16px;
        }

        .checkbox-container label {
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
        }

        .help-text {
            display: block;
            font-size: 0.75rem;
            color: #64748B;
            font-weight: 400;
            margin-top: 2px;
            line-height: 1.3;
        }

        /* --- BUTTONS --- */
        .btn-primary {
            width: 100%;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%);
            border: none;
            color: white;
            padding: 12px 24px;
            font-weight: 600;
            font-family: var(--font-main);
            font-size: 0.95rem;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 6px -1px rgba(2, 132, 199, 0.15);
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            box-shadow: 0 10px 15px -3px rgba(2, 132, 199, 0.25);
            transform: translateY(-1px);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .btn-loader {
            width: 18px;
            height: 18px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .btn-secondary {
            background-color: #F1F5F9;
            border: 1px solid var(--border-color);
            color: var(--text-heading);
            padding: 10px 20px;
            font-family: var(--font-main);
            font-size: 0.85rem;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.2s;
        }

        .btn-secondary:hover {
            background-color: #E2E8F0;
        }

        /* --- SCORECARDS --- */
        .scorecard-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .scorecard {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 16px;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        }

        .blue-left { border-left: 4px solid var(--primary); }
        .purple-left { border-left: 4px solid var(--purple); }
        .emerald-left { border-left: 4px solid var(--emerald); }
        .gray-left { border-left: 4px solid #64748B; }

        .card-label {
            font-size: 0.72rem;
            font-weight: 700;
            color: #64748B;
            letter-spacing: 0.05em;
            display: block;
            margin-bottom: 4px;
        }

        .scorecard h4 {
            font-family: var(--font-code);
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-heading);
            margin: 0;
        }

        /* --- ALERTS --- */
        .alert-banner {
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 24px;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from { transform: translateY(-10px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .alert-banner.amber {
            background-color: rgba(245, 158, 11, 0.06);
            border: 1px solid rgba(245, 158, 11, 0.2);
        }

        .alert-banner.emerald {
            background-color: rgba(16, 185, 129, 0.05);
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 9999px;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.05em;
            margin-bottom: 6px;
        }

        .badge-amber {
            background-color: var(--amber-bg);
            color: var(--amber-text);
            border: 1px solid #FDE68A;
        }

        .badge-emerald {
            background-color: var(--emerald-bg);
            color: var(--emerald-text);
            border: 1px solid #A7F3D0;
        }

        .alert-banner h3 {
            font-family: var(--font-code);
            font-size: 1.25rem;
            font-weight: 700;
            margin: 0 0 6px 0;
        }

        .alert-banner.amber h3 { color: var(--amber-text); }
        .alert-banner.emerald h3 { color: var(--emerald-text); }

        .alert-banner p {
            margin: 0;
            font-size: 0.9rem;
            line-height: 1.4;
            color: #475569;
        }

        /* --- PLOT CONTAINER --- */
        .workspace-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }

        .plot-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .plot-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .plot-header h4 {
            font-family: var(--font-code);
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text-heading);
            margin: 0;
        }

        .info-tag {
            font-size: 0.72rem;
            font-weight: 600;
            color: #64748B;
            background-color: #F1F5F9;
            padding: 2px 8px;
            border-radius: 4px;
        }

        .chart-canvas {
            height: 280px;
            background-color: #FFFFFF;
            border: 1px solid #F1F5F9;
            border-radius: 8px;
        }

        .chart-canvas-tall {
            height: 480px;
            background-color: #FFFFFF;
            border: 1px solid #F1F5F9;
            border-radius: 8px;
        }

        .zoom-inset-header {
            margin-top: 10px;
        }

        .zoom-title {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--primary);
            display: block;
        }

        .zoom-canvas {
            height: 160px;
            background-color: #FFFFFF;
            border: 1px solid #F1F5F9;
            border-radius: 8px;
        }

        /* --- BIOMARKERS TABLE --- */
        .table-container {
            margin-bottom: 24px;
        }

        .table-container h4 {
            font-family: var(--font-code);
            font-size: 1.1rem;
            font-weight: 700;
            margin: 0 0 4px 0;
            color: var(--text-heading);
        }

        .table-desc {
            font-size: 0.8rem;
            color: #64748B;
            margin: 0 0 16px 0;
        }

        .table-wrapper {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th {
            font-size: 0.78rem;
            font-weight: 600;
            color: #64748B;
            padding: 10px 16px;
            border-bottom: 2px solid var(--border-color);
        }

        td {
            font-size: 0.88rem;
            padding: 12px 16px;
            border-bottom: 1px solid #F1F5F9;
            color: #334155;
        }

        td a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }

        td a:hover {
            text-decoration: underline;
        }

        .progress-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .progress-bar-container {
            flex-grow: 1;
            background: #F1F5F9;
            height: 8px;
            border-radius: 999px;
            overflow: hidden;
            border: 1px solid #E2E8F0;
        }

        .progress-bar {
            height: 100%;
            border-radius: 999px;
        }

        .progress-val {
            font-size: 0.8rem;
            color: #475569;
            font-weight: bold;
            width: 24px;
            text-align: right;
        }

        /* --- ACCORDION PANEL --- */
        .accordion {
            margin-bottom: 40px;
            padding: 0;
            overflow: hidden;
        }

        .accordion-trigger {
            width: 100%;
            background: none;
            border: none;
            padding: 20px 24px;
            font-family: var(--font-code);
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text-heading);
            text-align: left;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            outline: none;
        }

