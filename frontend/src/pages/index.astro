            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            padding: 2px 6px;
            border-radius: 4px;
            margin-top: 4px;
        }

        .gauge-label.stable { background-color: var(--emerald-bg); color: var(--emerald-text); }
        .gauge-label.violated { background-color: var(--red-bg); color: var(--red-text); }

        .json-code {
            font-family: var(--font-code);
            font-size: 0.8rem;
            background-color: #0F172A;
            color: #38BDF8;
            padding: 16px;
            border-radius: 8px;
            overflow: auto;
            max-height: 180px;
            margin: 0 0 12px 0;
            border: 1px solid #334155;
        }

        /* --- HELPERS --- */
        .hidden { display: none !important; }
    </style>

    <!-- --- CLIENT-SIDE DASHBOARD SCRIPT --- -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const API_BASE = "http://127.0.0.1:8000";
            
            // UI elements
            const sampleSelect = document.getElementById('sample-select');
            const noiseSlider = document.getElementById('noise-slider');
            const noiseVal = document.getElementById('noise-val');
            const driftSlider = document.getElementById('drift-slider');
            const driftVal = document.getElementById('drift-val');
            const ghostCheckbox = document.getElementById('ghost-checkbox');
            const ebmSlider = document.getElementById('ebm-slider');
            const ebmVal = document.getElementById('ebm-val');
            const fileUpload = document.getElementById('file-upload');
            
            const analyzeBtn = document.getElementById('analyze-btn');
            const btnText = analyzeBtn.querySelector('.btn-text');
            const btnLoader = analyzeBtn.querySelector('.btn-loader');
            
            const scorecardExtract = document.getElementById('scorecard-extract');
            const scorecardStatus = document.getElementById('scorecard-status');
            const scorecardQc = document.getElementById('scorecard-qc');
            const scorecardQcBox = document.getElementById('scorecard-qc-box');
            
            const alertBanner = document.getElementById('alert-banner');
            const alertBadge = document.getElementById('alert-badge');
            const alertTitle = document.getElementById('alert-title');
            const alertDesc = document.getElementById('alert-desc');
            
            const tbody = document.getElementById('biomarker-tbody');
            
            const accordionToggle = document.getElementById('accordion-toggle');
            const accordionPanel = document.getElementById('accordion-panel');
            
            const gaugeCircle = document.getElementById('gauge-circle');
            const gaugeVal = document.getElementById('gauge-val');
            const gaugeLbl = document.getElementById('gauge-lbl');
            const jsonPayload = document.getElementById('json-payload');
            const downloadJsonBtn = document.getElementById('download-json-btn');

            function interpolate(x, y, targetX) {
                const targetY = [];
                for (let k = 0; k < targetX.length; k++) {
                    const tx = targetX[k];
                    if (tx <= x[0]) {
                        targetY.push(y[0]);
                    } else if (tx >= x[x.length - 1]) {
                        targetY.push(y[y.length - 1]);
                    } else {
                        let i = 0;
                        while (i < x.length - 1 && x[i+1] < tx) {
                            i++;
                        }
                        const x0 = x[i];
                        const x1 = x[i+1];
                        const y0 = y[i];
                        const y1 = y[i+1];
                        const val = y0 + (y1 - y0) * (tx - x0) / (x1 - x0);
                        targetY.push(val);
                    }
                }
                return targetY;
            }

            async function handleFileUpload(file) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        try {
                            const text = e.target.result;
                            const lines = text.split("\n");
                            if (lines.length < 10) throw new Error("File is empty or too short.");
                            
                            const sampleLine = lines[0];
                            let delim = null;
                            if (sampleLine.includes("\t")) delim = "\t";
                            else if (sampleLine.includes(";")) delim = ";";
                            else if (sampleLine.includes(",")) delim = ",";
                            
                            const data = [];
                            let hasHeader = false;
                            const firstParts = delim ? sampleLine.split(delim) : sampleLine.trim().split(/\s+/);
                            if (firstParts.length >= 2) {
                                if (isNaN(parseFloat(firstParts[0])) || isNaN(parseFloat(firstParts[1]))) {
                                    hasHeader = true;
                                }
                            }
                            
                            const startRow = hasHeader ? 1 : 0;
                            for (let i = startRow; i < lines.length; i++) {
                                const line = lines[i].trim();
                                if (!line) continue;
                                const parts = delim ? line.split(delim) : line.split(/\s+/);
                                if (parts.length >= 2) {
                                    const ppm = parseFloat(parts[0].trim());
                                    const intensity = parseFloat(parts[1].trim());
                                    if (!isNaN(ppm) && !isNaN(intensity)) {
                                        data.push({ ppm, intensity });
                                    }
                                }
                            }
                            
                            if (data.length < 10) throw new Error("No numeric coordinates parsed. Ensure 2 columns exist (PPM, Intensity).");
                            
                            data.sort((a, b) => a.ppm - b.ppm);
                            const rawX = data.map(d => d.ppm);
                            const rawY = data.map(d => d.intensity);
                            
                            const targetX = [];
                            for (let i = 0; i < 4000; i++) {
                                targetX.push(0.0 + (10.0 - 0.0) * i / 3999);
                            }
                            
                            let targetY = interpolate(rawX, rawY, targetX);
                            
                            const maxVal = Math.max(...targetY);
                            if (maxVal > 0) {
                                targetY = targetY.map(v => (v / maxVal) * 3.5);
                            }
                            
                            resolve({
                                ppm_axis: targetX,
                                raw_spectrum: targetY,
                                drifted_ppm: targetX,
                                annotations: [],
                                sample_type: "Uploaded_NMR"
                            });
                        } catch (err) {
                            reject(err);
                        }
                    };
                    reader.onerror = () => reject(new Error("File reading error."));
                    reader.readAsText(file);
                });
            }

            let activeData = null;
            let currentPayload = null;

            // Slider listeners
            noiseSlider.addEventListener('input', (e) => {
                noiseVal.textContent = parseFloat(e.target.value).toFixed(3);
                loadActiveSample();
            });
            driftSlider.addEventListener('input', (e) => {
                const val = parseFloat(e.target.value);
                driftVal.textContent = val >= 0 ? `+${val.toFixed(3)}` : val.toFixed(3);
                loadActiveSample();
            });
            ghostCheckbox.addEventListener('change', () => {
                loadActiveSample();
            });
            ebmSlider.addEventListener('input', (e) => {
                ebmVal.textContent = parseFloat(e.target.value).toFixed(1);
            });
            sampleSelect.addEventListener('change', () => {
                // Update scorecard text
                const textMapping = {
                    "Plant_Extract_A": "Sugarcane Extract",
                    "Plant_Extract_B": "Coffee Extract",
                    "Plant_Extract_C": "Soybean Extract"
                };
                scorecardExtract.textContent = textMapping[sampleSelect.value];
                loadActiveSample();
            });

            // Accordion listener
            accordionToggle.addEventListener('click', () => {
                accordionToggle.classList.toggle('active');
                accordionPanel.classList.toggle('hidden');
            });

            // Helper downsample function (Plotly efficiency)
            function downsample(x, y, target = 2000) {
                const factor = Math.floor(x.length / target);
                if (factor <= 1) return { x, y };
                const x_ds = [];
                const y_ds = [];
                for (let i = 0; i < target; i++) {
                    const idx = i * factor;
                    x_ds.push(x[idx]);
                    // Max-pool to preserve peak shapes
                    let maxVal = -Infinity;
                    for (let j = 0; j < factor; j++) {
                        if (y[idx + j] > maxVal) maxVal = y[idx + j];
                    }
                    y_ds.push(maxVal);
                }
                return { x: x_ds, y: y_ds };
            }

            // Fetch and plot current sample
            async function loadActiveSample() {
                try {
                    const sampleType = sampleSelect.value;
                    const noise = parseFloat(noiseSlider.value);
                    const drift = parseFloat(driftSlider.value);
                    const addGhost = ghostCheckbox.checked;
                    
                    const res = await fetch(`${API_BASE}/api/sample?sample_type=${sampleType}&noise_level=${noise}&shift_drift=${drift}&add_ghost=${addGhost}`);
                    activeData = await res.json();
                    
                    renderPlots();
                    renderBiomarkers();
                } catch (e) {
                    console.error("Error loading sample:", e);
                }
            }

            // Plotly rendering
            function renderPlots() {
                if (!activeData) return;

                const { ppm_axis, raw_spectrum, drifted_ppm, annotations, sample_type } = activeData;
                
                // 1. Plotly Pane A (Raw Drifted vs Aligned)
                const dsRaw = downsample(drifted_ppm, raw_spectrum);
                const dsAlg = downsample(ppm_axis, raw_spectrum);
                
                const traceRaw = {
                    x: dsRaw.x,
                    y: dsRaw.y,
                    mode: 'lines',
                    line: { color: 'rgba(239, 68, 68, 0.65)', width: 1.5 },
                    name: 'Patient Raw (Drifted)'
                };
                
                const traceAligned = {
                    x: dsAlg.x,
                    y: dsAlg.y,
                    mode: 'lines',
                    line: { color: '#059669', width: 2 },
                    name: 'Patient Aligned'
                };
                
                // Biomarker markers
                const peakMap = {};
                annotations.forEach(ann => {
                    const comp = ann.compound_name;
                    if (!peakMap[comp] || ann.relative_intensity > peakMap[comp].intensity) {
                        peakMap[comp] = { ppm: ann.ppm_position, intensity: ann.relative_intensity };
                    }
                });
                
                const tracePeaks = {
                    x: Object.values(peakMap).map(p => p.ppm),
                    y: Object.values(peakMap).map(p => p.intensity),
                    mode: 'markers+text',
                    text: Object.keys(peakMap),
                    textposition: 'top center',
                    textfont: { color: '#B45309', size: 10, family: 'Space Grotesk' },
                    marker: { color: '#D97706', size: 9, symbol: 'triangle-up' },
                    name: 'Identified Biomarkers',
                    hoverinfo: 'text'
                };

                const layoutOverlay = {
                    plot_bgcolor: '#FFFFFF',
                    paper_bgcolor: 'rgba(0,0,0,0)',
                    xaxis: { title: 'Chemical Shift (ppm)', autorange: 'reversed', gridcolor: '#F1F5F9' },
                    yaxis: { title: 'Intensity', gridcolor: '#F1F5F9' },
                    margin: { l: 40, r: 20, t: 10, b: 40 },
                    height: 280,
                    legend: { font: { size: 10 }, x: 0.05, y: 0.95 }
                };

                Plotly.newPlot('plotly-overlay', [traceRaw, traceAligned, tracePeaks], layoutOverlay);

                // 2. High-Res Zoom Inset (Sugar/Aromatic/Aliphatic depending on class)
                let zoomMin, zoomMax, zoomTitle;
                if (sample_type === "Plant_Extract_A") {
                    zoomMin = 3.2; zoomMax = 4.5; zoomTitle = "Sugar Region (3.2 - 4.5 ppm)";
                } else if (sample_type === "Plant_Extract_B") {
                    zoomMin = 6.0; zoomMax = 8.0; zoomTitle = "Aromatic Region (6.0 - 8.0 ppm)";
                } else {
                    zoomMin = 0.8; zoomMax = 2.8; zoomTitle = "Aliphatic & Amino Acid Region (0.8 - 2.8 ppm)";
                }
                
                document.querySelector('.zoom-title').textContent = `🔍 High-Resolution Zoom Inset: ${zoomTitle}`;

                // Filter points in zoom range
                const zoomX = [];
                const zoomY = [];
                for (let i = 0; i < drifted_ppm.length; i++) {
                    if (drifted_ppm[i] >= zoomMin && drifted_ppm[i] <= zoomMax) {
                        zoomX.push(drifted_ppm[i]);
                        zoomY.push(raw_spectrum[i]);
                    }
                }
                const dsZoom = downsample(zoomX, zoomY, 1000);
                
                const traceZoom = {
                    x: dsZoom.x,
                    y: dsZoom.y,
                    mode: 'lines',
                    line: { color: '#0EA5E9', width: 2 },
                    name: 'Zoom Region'
                };
                
                const zoomAnnList = annotations.filter(a => a.ppm_position >= zoomMin && a.ppm_position <= zoomMax)
                                               .sort((a,b) => b.relative_intensity - a.relative_intensity)
                                               .slice(0, 6);
                
                const traceZoomPeaks = {
                    x: zoomAnnList.map(a => a.ppm_position - parseFloat(driftSlider.value)),
                    y: zoomAnnList.map(a => a.relative_intensity),
                    mode: 'markers+text',
                    text: zoomAnnList.map(a => a.compound_name),
                    textposition: 'top center',
                    textfont: { color: '#B45309', size: 9, family: 'Space Grotesk' },
                    marker: { color: '#D97706', size: 8, symbol: 'triangle-up' }
                };

                const layoutZoom = {
                    plot_bgcolor: '#FFFFFF',
                    paper_bgcolor: 'rgba(0,0,0,0)',
                    xaxis: { range: [zoomMax, zoomMin], gridcolor: '#F1F5F9' },
                    yaxis: { showticklabels: false, gridcolor: '#F1F5F9' },
                    margin: { l: 40, r: 20, t: 10, b: 20 },
                    height: 160,
                    showlegend: false
                };

                Plotly.newPlot('plotly-zoom', [traceZoom, traceZoomPeaks], layoutZoom);

                // 3. Waterfall Stack Stack (Pane B)
                renderWaterfall();
            }

            async function renderWaterfall() {
                try {
                    // Fetch all standard references statically (zero noise, zero drift)
                    const resA = await fetch(`${API_BASE}/api/sample?sample_type=Plant_Extract_A&noise_level=0.0&shift_drift=0.0`);
                    const resB = await fetch(`${API_BASE}/api/sample?sample_type=Plant_Extract_B&noise_level=0.0&shift_drift=0.0`);
                    const resC = await fetch(`${API_BASE}/api/sample?sample_type=Plant_Extract_C&noise_level=0.0&shift_drift=0.0`);
                    
                    const dataA = await resA.json();
                    const dataB = await resB.json();
                    const dataC = await resC.json();
                    
                    const dsA = downsample(dataA.ppm_axis, dataA.raw_spectrum);
                    const dsB = downsample(dataB.ppm_axis, dataB.raw_spectrum);
                    const dsC = downsample(dataC.ppm_axis, dataC.raw_spectrum);
                    
                    const offset = 1.3;
                    
                    const traceA = {
                        x: dsA.x,
                        y: dsA.y,
                        mode: 'lines',
                        line: { color: '#10B981', width: 1.5 },
                        name: 'Ref: Sugarcane (Sugar-Rich)'
                    };
                    
                    const traceB = {
                        x: dsB.x,
                        y: dsB.y,
                        mode: 'lines',
                        line: { color: '#EC4899', width: 1.5 },
                        name: 'Ref: Coffee (Aromatic-Rich)'
                    };
                    
                    const traceC = {
                        x: dsC.x,
                        y: dsC.y,
                        mode: 'lines',
                        line: { color: '#8B5CF6', width: 1.5 },
                        name: 'Ref: Soybean (Amino-Acid-Rich)'
                    };
                    
                    // Apply offsets
                    const traceBOffset = { ...traceB, y: dsB.y.map(v => v + offset) };
                    const traceCOffset = { ...traceC, y: dsC.y.map(v => v + 2 * offset) };
                    
                    const layoutStack = {
                        plot_bgcolor: '#FFFFFF',
                        paper_bgcolor: 'rgba(0,0,0,0)',
                        xaxis: { title: 'Chemical Shift (ppm)', autorange: 'reversed', gridcolor: '#F1F5F9' },
                        yaxis: { title: 'Intensity (Stacked Offset)', showticklabels: false, gridcolor: '#F1F5F9' },
                        margin: { l: 40, r: 20, t: 10, b: 40 },
                        height: 480,
                        legend: { font: { size: 9 }, x: 0.05, y: 0.95 }
                    };
                    
                    Plotly.newPlot('plotly-waterfall', [traceCOffset, traceBOffset, traceA], layoutStack);
                } catch (e) {
                    console.error("Error drawing waterfall stack:", e);
                }
            }

            // Quantitative Biomarkers Table
            function renderBiomarkers() {
                if (!activeData) return;
                
                const { annotations } = activeData;
                tbody.innerHTML = '';
                
                // Group by compound
                const compoundGroup = {};
                annotations.forEach(ann => {
                    const name = ann.compound_name;
                    if (!compoundGroup[name] || ann.relative_intensity > compoundGroup[name].intensity) {
                        compoundGroup[name] = ann;
                    }
                });

                // HMDB static formulas mapping
                const formulas = {
                    "Sucrose": "C12H22O11", "Glucose": "C6H12O6", "Fructose": "C6H12O6", "Maltose": "C12H22O11", "Xylose": "C5H10O5",
                    "Valine": "C5H11NO2", "Leucine": "C6H13NO2", "Isoleucine": "C6H13NO2", "Alanine": "C3H7NO2", "Threonine": "C4H9NO3",
                    "Citrate": "C6H8O7", "Succinate": "C4H6O4", "Glutamate": "C5H9NO4", "Acetate": "C2H4O2", "Formate": "CH2O2",
                    "Propionate": "C3H6O2", "Chlorogenate": "C16H18O9", "Tyrosine": "C9H11NO3", "Phenylalanine": "C9H11NO2",
                    "Tryptophan": "C11H12N2O2", "Histidine": "C6H9N3O2", "Methanol": "CH4O", "Ethanol": "C2H6O", "Choline": "C5H13NO",
                    "O-Phosphocholine": "C5H13NO4P", "4-Aminobutyrate": "C4H9NO2", "Uridine": "C9H12N2O6", "Nicotinate": "C6H5NO2"
                };

                const hmdbIds = {
                    "Sucrose": "HMDB0000258", "Glucose": "HMDB0000122", "Fructose": "HMDB0000660", "Maltose": "HMDB0000163", "Xylose": "HMDB0000098",
                    "Valine": "HMDB0000883", "Leucine": "HMDB0000687", "Isoleucine": "HMDB0000172", "Alanine": "HMDB0000161", "Threonine": "HMDB0000167",
                    "Citrate": "HMDB0000094", "Succinate": "HMDB0000254", "Glutamate": "HMDB0000148", "Acetate": "HMDB0000042", "Formate": "HMDB0000142",
                    "Propionate": "HMDB0000237", "Chlorogenate": "HMDB0003164", "Tyrosine": "HMDB0000158", "Phenylalanine": "HMDB0000159",
                    "Tryptophan": "HMDB0000929", "Histidine": "HMDB0000177", "Methanol": "HMDB0001875", "Ethanol": "HMDB0000108", "Choline": "HMDB0000097",
                    "O-Phosphocholine": "HMDB0001565", "4-Aminobutyrate": "HMDB0000112", "Uridine": "HMDB0000296", "Nicotinate": "HMDB0001488"
                };

                Object.keys(compoundGroup).forEach(name => {
                    const formula = formulas[name] || "N/A";
                    const dbId = hmdbIds[name] || "HMDB0000000";
                    const confidence = 95; // base mock
                    
                    const weight = compoundGroup[name].relative_intensity;
                    const percent = Math.min(Math.floor((weight / 2.0) * 100), 100);
                    
                    let barColor = "#0284C7";
                    if (percent > 75) barColor = "#10B981";
                    else if (percent < 30) barColor = "#F59E0B";
                    
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td style="font-weight: 600; color: #0F172A;">${name}</td>
                        <td style="color: #64748B;">${formula}</td>
                        <td><a href="https://hmdb.ca/metabolites/${dbId}" target="_blank">${dbId} 🔗</a></td>
                        <td style="font-weight: bold; color: #059669;">${confidence}%</td>
                        <td>
                            <div class="progress-wrapper">
                                <div class="progress-bar-container">
                                    <div class="progress-bar" style="background-color: ${barColor}; width: ${percent}%;"></div>
                                </div>
                                <span class="progress-val">${weight.toFixed(1)}</span>
                            </div>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });
            }

            // Run Analysis workflow
            analyzeBtn.addEventListener('click', async () => {
                if (!activeData) return;

                btnText.textContent = "Processing Signal Models...";
                btnLoader.classList.remove('hidden');
                analyzeBtn.disabled = true;

                try {
                    const ebmThreshold = parseFloat(ebmSlider.value);
                    const drift = parseFloat(driftSlider.value);
                    const addGhost = ghostCheckbox.checked;

                    const bodyPayload = {
                        raw_spectrum: activeData.raw_spectrum,
                        label: sampleSelect.value,
                        ebm_threshold: ebmThreshold,
                        shift_drift: drift,
                        add_ghost: addGhost
                    };

                    const res = await fetch(`${API_BASE}/api/analyze`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(bodyPayload)
                    });
                    
                    const result = await res.json();
                    currentPayload = result.telemetry;
                    
                    // Render tech metrics
                    renderTechMetrics(result);
                    
                    // Update scores
                    scorecardStatus.textContent = "COMPLETED";
                    const isGhost = result.diagnostics.ghost_peak_detected;
                    
                    if (isGhost) {
                        scorecardQc.textContent = "ANOMALY RESOLVED";
                        scorecardQcBox.className = "scorecard gray-left";
                        scorecardQcBox.style.borderLeftColor = "var(--amber)";
                        
                        alertBanner.className = "alert-banner amber";
                        alertBadge.textContent = "⚠️ PHYSICAL ANOMALY RESOLVED";
                        alertTitle.textContent = "Diagnostic Alert: Synthetic Ghost Peak Suppressed";
                        alertDesc.textContent = `The physics-constrained Energy-Based Model (EBM) detected an anomalous contaminant peak at 4.15 ppm. Violating the physical spin-spin coupling height ratios of standard organic molecules, the anomaly was successfully suppressed. Match confidence has been adjusted.`;
                        alertBanner.classList.remove('hidden');

                        // Save telemetry trace trigger automatically
                        await fetch(`${API_BASE}/api/telemetry`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                sample_id: "NMR-SAMPLE-2026-X99",
                                raw_energy_score: result.diagnostics.raw_energy_score,
                                energy_threshold: ebmThreshold,
                                details: "Ghost peak identified and telemetry recorded from frontend click."
                            })
                        });
                    } else {
                        scorecardQc.textContent = "PHYSICS PASSED";
                        scorecardQcBox.className = "scorecard emerald-left";
                        scorecardQcBox.style.borderLeftColor = "var(--emerald)";
                        
                        alertBanner.className = "alert-banner emerald";
                        alertBadge.textContent = "✅ CLINICAL REPORT STABLE";
                        alertTitle.textContent = "Diagnostic Screening: Consistent Metabolite Fingerprint";
                        alertDesc.textContent = `NMR fingerprint satisfies all physics-chemical constraints. Aligned via Latent Neural ODE Solver. No anomalous signals identified.`;
                        alertBanner.classList.remove('hidden');
                    }
                } catch (e) {
                    console.error("Error executing analysis:", e);
                } finally {
                    btnText.textContent = "⚡ Run AI Diagnostic Analysis";
                    btnLoader.classList.add('hidden');
                    analyzeBtn.disabled = false;
                }
            });

            // Renders advanced tech metrics
            function renderTechMetrics(result) {
                const { latent_features, trajectory_steps, diagnostics } = result;

                // 1. Latent Feature activation
                const traceLatent = {
                    y: latent_features.slice(0, 64),
                    type: 'bar',
                    marker: { color: '#10B981', opacity: 0.85 }
                };
                const layoutLatent = {
                    plot_bgcolor: '#FFFFFF',
                    paper_bgcolor: 'rgba(0,0,0,0)',
                    xaxis: { title: 'Latent Dimension ID', gridcolor: '#F1F5F9' },
                    yaxis: { title: 'Activation', gridcolor: '#F1F5F9' },
                    margin: { l: 40, r: 20, t: 10, b: 40 },
                    height: 200,
                    showlegend: false
                };
                Plotly.newPlot('plotly-latent', [traceLatent], layoutLatent);

                // 2. Latent ODE Trajectory
                const steps = trajectory_steps.length;
                const dimsToPlot = [4, 18, 42, 88];
                const colors = ['#0284C7', '#6366F1', '#EC4899', '#10B981'];
                const tracesOde = [];
                
                dimsToPlot.forEach((dim, idx) => {
                    const values = [];
                    for(let s = 0; s < steps; s++) {
                        values.push(trajectory_steps[s][dim]);
                    }
                    tracesOde.push({
                        x: Array.from({length: steps}, (_, i) => i),
                        y: values,
                        mode: 'lines+markers',
                        line: { color: colors[idx], width: 2.5 },
                        marker: { size: 6 },
                        name: `Dim ${dim}`
                    });
                });
                
                const layoutOde = {
                    plot_bgcolor: '#FFFFFF',
                    paper_bgcolor: 'rgba(0,0,0,0)',
                    xaxis: { title: 'ODE Integration Steps', gridcolor: '#F1F5F9' },
                    yaxis: { title: 'State Activation', gridcolor: '#F1F5F9' },
                    margin: { l: 40, r: 20, t: 10, b: 40 },
                    height: 200,
                    legend: { font: { size: 8 } }
                };
                Plotly.newPlot('plotly-ode', tracesOde, layoutOde);

                // 3. EBM Circular Gauge meter
                const energy = diagnostics.raw_energy_score;
                gaugeVal.textContent = energy.toFixed(4);
                const isViolated = energy > parseFloat(ebmSlider.value);
                
                if (isViolated) {
                    gaugeCircle.className = "gauge-circle violated";
                    gaugeLbl.textContent = "ANOMALY";
                    gaugeLbl.className = "gauge-label violated";
                } else {
                    gaugeCircle.className = "gauge-circle stable";
                    gaugeLbl.textContent = "STABLE";
                    gaugeLbl.className = "gauge-label stable";
                }

                // 4. Structured JSON Payload
                jsonPayload.textContent = JSON.stringify(result.telemetry, null, 4);
            }

            // Download EMR JSON button action
            downloadJsonBtn.addEventListener('click', () => {
                if (!currentPayload) return;
                const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(currentPayload, null, 4));
                const dlAnchor = document.createElement('a');
                dlAnchor.setAttribute("href", dataStr);
                dlAnchor.setAttribute("download", `clinical_report_${currentPayload.diagnostic_reports[0].sample_id}.json`);
                document.body.appendChild(dlAnchor);
                dlAnchor.click();
                dlAnchor.remove();
            });

            fileUpload.addEventListener('change', async (e) => {
                const file = e.target.files[0];
                if (!file) return;
                
                btnText.textContent = "Parsing NMR File...";
                analyzeBtn.disabled = true;
                
                try {
                    activeData = await handleFileUpload(file);
                    
                    const resA = await fetch(`${API_BASE}/api/sample?sample_type=Plant_Extract_A&noise_level=0.0&shift_drift=0.0`);
                    const resB = await fetch(`${API_BASE}/api/sample?sample_type=Plant_Extract_B&noise_level=0.0&shift_drift=0.0`);
                    const resC = await fetch(`${API_BASE}/api/sample?sample_type=Plant_Extract_C&noise_level=0.0&shift_drift=0.0`);
                    
                    const dataA = await resA.json();
                    const dataB = await resB.json();
                    const dataC = await resC.json();
                    
                    function getCorrelation(x, y) {
                        const n = x.length;
                        let sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0, sumY2 = 0;
                        for (let i = 0; i < n; i++) {
                            sumX += x[i];
                            sumY += y[i];
                            sumXY += x[i] * y[i];
                            sumX2 += x[i] * x[i];
                            sumY2 += y[i] * y[i];
                        }
                        const num = n * sumXY - sumX * sumY;
                        const den = Math.sqrt((n * sumX2 - sumX * sumX) * (n * sumY2 - sumY * sumY));
                        return den === 0 ? 0 : num / den;
                    }
                    
                    const corrA = getCorrelation(activeData.raw_spectrum, dataA.raw_spectrum);
                    const corrB = getCorrelation(activeData.raw_spectrum, dataB.raw_spectrum);
                    const corrC = getCorrelation(activeData.raw_spectrum, dataC.raw_spectrum);
                    
                    let bestCorr = corrA;
                    let bestClass = "Plant_Extract_A";
                    let bestName = "Sugarcane Extract";
                    
                    if (corrB > bestCorr) {
                        bestCorr = corrB;
                        bestClass = "Plant_Extract_B";
                        bestName = "Coffee Extract";
                    }
                    if (corrC > bestCorr) {
                        bestCorr = corrC;
                        bestClass = "Plant_Extract_C";
                        bestName = "Soybean Extract";
                    }
                    
                    activeData.sample_type = bestClass;
                    activeData.annotations = bestClass === "Plant_Extract_A" ? dataA.annotations : (bestClass === "Plant_Extract_B" ? dataB.annotations : dataC.annotations);
                    
                    sampleSelect.value = bestClass;
                    scorecardExtract.textContent = `${bestName} (${(bestCorr * 100).toFixed(0)}% match)`;
                    
                    renderPlots();
                    renderBiomarkers();
                    
                    alertBanner.className = "alert-banner emerald";
                    alertBadge.textContent = "✅ FILE IMPORT SUCCESS";
                    alertTitle.textContent = `Parsed Real NMR File: ${file.name}`;
                    alertDesc.textContent = `NMR data successfully interpolated to 4000 points and mapped to ${bestName} based on ${(bestCorr * 100).toFixed(1)}% fingerprint match. Ready to run deep learning clinical analysis on RTX 4060 GPU!`;
                    alertBanner.classList.remove('hidden');
                    
                } catch (err) {
                    console.error("Error loading file:", err);
                    alertBanner.className = "alert-banner";
                    alertBanner.style.backgroundColor = "var(--red-bg)";
                    alertBanner.style.border = "1px solid var(--red)";
                    
                    alertBadge.textContent = "❌ PARSE ERROR";
                    alertBadge.className = "badge";
                    alertBadge.style.backgroundColor = "var(--red-bg)";
                    alertBadge.style.color = "var(--red-text)";
                    alertBadge.style.border = "1px solid var(--red)";
                    
                    alertTitle.textContent = "File Import Failure";
                    alertTitle.style.color = "var(--red-text)";
                    alertDesc.textContent = `Error reading NMR file: ${err.message}`;
                    alertBanner.classList.remove('hidden');
                } finally {
                    btnText.textContent = "⚡ Run AI Diagnostic Analysis";
                    analyzeBtn.disabled = false;
                }
            });

            // Initial load
            loadActiveSample();
        });
    </script>
</body>
</html>
