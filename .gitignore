MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so they can be injected at build time.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nosenv/
.pytest_cache/
.unittest_cache/
.ipynb_checkpoints

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if hopes is to let users install from Pipfile
#   without locking dependencies, ignore it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed.
#poetry.lock

# venv
.venv/
venv/
ENV/
env/

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo

# System Files
.DS_Store
Thumbs.db

# Clinical outputs (dynamically generated EHR reports & active learning logs)
clinical_report.json
anomalous_peaks_feedback.json

# Local frontend build caches and dependencies
frontend/.astro/
frontend/dist/
frontend/node_modules/
node_modules/

# Archived friend's sandbox POC (cloned locally for reference, ignored from version control)
BDI-flow-test/


